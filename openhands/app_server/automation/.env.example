# =============================================================================
# OpenHands Automation Module — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
#
# Required vars are marked [REQUIRED]; all others are optional.
# =============================================================================

# ── GitHub Integration ──────────────────────────────────────────────────────
# [REQUIRED for GitHub automation]
# GitHub personal access token with repo scope.
# Used to post PR comments via POST /api/v1/git/github/webhook/comment.
GITHUB_TOKEN=

# ── Jira Integration ────────────────────────────────────────────────────────
# [REQUIRED for Jira automation]
# Jira credentials for commenting on issues.
JIRA_EMAIL=
JIRA_API_KEY=

# [REQUIRED for Jira automation]
# Jira instance domain, e.g. "your-domain.atlassian.net"
# Alternatively, set JIRA_URL to the full base URL.
JIRA_DOMAIN=
# JIRA_URL=https://your-domain.atlassian.net

# [REQUIRED for Jira assignment filtering]
# Atlassian account ID of the user whose assignments trigger automations.
# Leave empty to process all assignment events regardless of assignee.
# Format: "712020:31da0b8e-ed93-4098-8ddc-582475da756c"
JIRA_TARGET_ACCOUNT_ID=

# [Optional] Jira webhook secret for validating incoming webhook payloads.
# If set, the server will verify the X-Hub-Signature header on webhook requests.
JIRA_WEBHOOK_SECRET=

# ── Webhook Secrets (Repository Mappings) ──────────────────────────────────
# These are stored per-repository in the database via the admin API
# (POST /api/v1/admin/jira-project-repos). They are not set via .env.
# See the admin_router module for repository mapping management.

# ── Observability ──────────────────────────────────────────────────────────
# (Langfuse has been removed — traces are no longer created)
