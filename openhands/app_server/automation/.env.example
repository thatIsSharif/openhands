GITHUB_TOKEN=
JIRA_EMAIL=
JIRA_API_KEY=
JIRA_DOMAIN=
JIRA_TARGET_ACCOUNT_ID=
JIRA_WEBHOOK_SECRET=

# ── Complexity-based model routing (Jira) ─────────────────────────
# All three must be set for the feature to activate.  When a Jira
# webhook arrives the system classifies the task and routes it to
# the matching model tier.
OH_JIRA_COMPLEX_MODEL=openai/deepseek-v4-pro
OH_JIRA_MEDIUM_MODEL=openai/MiMo-V2.5
OH_JIRA_LOW_MODEL=openai/MiniMax M3

# ── Complexity analysis LLM configuration ─────────────────────────
OH_JIRA_ANALYSIS_MODEL=openai/deepseek-v4-flash-free
OH_JIRA_ANALYSIS_API_KEY=
OH_JIRA_ANALYSIS_BASE_URL=https://opencode.ai/zen/go/v1
